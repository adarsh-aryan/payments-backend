############################
# App Environment Variables #
############################

# Option A: Single DATABASE_URL (recommended)
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/payments

# Option B: Individual Postgres settings (used if DATABASE_URL is not set)
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=payments

# If none of the above are set, the app falls back to SQLite at sqlite:///./data.db
